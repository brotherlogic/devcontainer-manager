[Unit]
Description=Devcontainer Manager Daemon
After=network-online.target
[Service]
Type=simple
# Pull and rebuild on startup
ExecStartPre=/bin/bash -c "cd %PROJECT_DIR% && (git fetch -p; git merge origin/main  \|\| true) && %GO_CMD% build -o %h/.local/bin/devcontainer-manager main.go"
# Assumes the binary is installed here
ExecStart=%h/.local/bin/devcontainer-manager
Restart=always
RestartSec=10
# Passes DBUS info so notify-send desktop notifications work from the background
Environment="DISPLAY=:0"
Environment="DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/%U/bus"
[Install]
WantedBy=default.target